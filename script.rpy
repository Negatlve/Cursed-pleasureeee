label return_to_epilogue:
    # Плавный переход
    scene black with dissolve
    pause 0.5
    
    # Снова показываем экран эпилога
    call screen simple_elegant_epilogue
    
    # После выбора на экране
    return
label play_bonus_video:
    # Скрываем экран
    $ renpy.hide_screen("simple_elegant_epilogue")
    
    # Плавный переход
    scene black with dissolve
    
    # Загружаем видео
    if renpy.loadable("videos/anim13.webm"):
        # Используем Movie для фона
        show expression Movie(
            play="videos/anim13.webm",
            loop=True,
            size=(1920, 1080)  # Подставьте размер вашего видео
        ) as bg_video
        with dissolve
    else:
        # Альтернативный фон
        scene expression "#1a1a2e" with dissolve
    
    # Небольшая пауза для загрузки видео
    pause 0.5
    
    # ОБЫЧНЫЙ ДИАЛОГ В ИГРЕ
    # Вы можете использовать всех персонажей, спрайты и т.д.
    yth "Блять…наконец-то я закончил первую версию."
    yth "Теперь можно и по-настоящему расслабиться."
    you "Давай по интенсивней, тёть Линда, не вижу радости на твоем лице."
    l "*glrk… gluck…*"
    you "Глубже… да, вот так… до конца."
    l "*Mmhph…!! Hrrk…!*"
    you "Потише, шлюха. Или я покажу всем видео, где твой сын кончает тебе на лицо!"
    l "*…ghhhk…*"
    you "Вот так бы сразу. Глотай до самых яиц и не вякай."
    $ persistent.gallery_bonus1 = True

    # ← ВОТ ЭТО ГЛАВНОЕ ИЗМЕНЕНИЕ (3 строчки)
    if is_gallery_replay:
        return
    # Возвращаемся
    hide bg_video with dissolve
    jump return_to_epilogue
label show_epilogue:
    # Останавливаем музыку
    stop music fadeout 2.0
    
    # Плавный переход
    scene black with Dissolve(1.5)
    
    
    
    # Показываем эпилог (выберите один вариант)
    call screen simple_elegant_epilogue  # Гарантированно работает
    # или call screen beautiful_epilogue   # Более сложный
    
    # После закрытия
    scene black with dissolve
    
    # Сохраняем прогресс
    $ persistent.prologue_completed = True
    $ renpy.save("epilogue_final")
    
    return
