default last_scene_bg = "#000000"

transform story_transform:
    fit "contain"
    xalign 0.5 yalign 0.5

# Прогресс-бар только для видео
screen video_progress:
    frame background None xysize (1920, 20) ypos 30 xalign 0.5
    bar value AnimatedValue(0.0, 1.0, 6.0):   # 6 секунд — длина твоего webp
        xsize 1880 ysize 8
        left_bar "#ffffff" right_bar "#33333399"
screen jessa_inspect():

    default img_height = 2160
    default screen_height = 1080

    # стартовое положение: ноги видны
    default scroll_y = -(img_height - screen_height)

    fixed:
        # Крупное изображение
        add "5.webp" xpos 0.5 xanchor 0.5 ypos scroll_y yanchor 0.0

    # Колесико: прокрутка вверх/вниз
    key "mousedown_5" action SetScreenVariable(
        "scroll_y", max(scroll_y - 20, -(img_height - screen_height))  # вверх: показываем голову
    )
    key "mousedown_4" action SetScreenVariable(
        "scroll_y", min(scroll_y + 20, 0)  # вниз: показываем ноги
    )

    # Выход из экрана
    key "mouseup_1" action Return()
    key "K_ESCAPE" action Return()

    # Подсказка в верхнем правом углу
    text "Wheel ↑/↓ • LM/Esc = Exit" size 28 color "#cccccc" xalign 0.98 yalign 0.02
