    pol "Эй, подожди! Ты в курсе, что эта игра строго 18+?"
    pol "Здесь нагота, секс-сцены, табуированные отношения, коррупция, доминирование, элементы принуждения и другие взрослые фетиши."  
    pol "Все персонажи старше 18 лет и вымышлены."
    pol  "Продолжая, ты подтверждаешь свой возраст и согласие."

    # Menu с выбором (кликабельно, как в игре)
    label splashscreen:
    # If already confirmed — skip straight to main menu
    if persistent.viewer_18:
        return

    scene bg01 with fade

    pol "Hey, wait a second! You know this game is strictly 18+, right?"
    pol "It contains nudity, explicit sex scenes, taboo relationships, corruption, domination, coercion elements, and plenty of other adult fetishes."
    pol "All characters are over 18 and completely fictional."
    pol "By continuing you confirm that you are of legal age and consent to adult content."

    menu:
        "Yes, I am 18 years old or older. I agree.":
            scene bg02 with dissolve
            pol "Perfect! Come on in and enjoy the {i}adult{/i} game! ;)"
            $ persistent.viewer_18 = True
            "Thank you for confirming!"
            pause 2.0
            return

        "No, I am under 18.":
            scene bg03 with vpunch
            stop music fadeout 1.0
            pol "Then get the hell out of here! This game isn’t for kids."
            centered "This game is intended ONLY for adults 18+."
            "Please close the game now."
            pause 3.0
            $ renpy.quit()
